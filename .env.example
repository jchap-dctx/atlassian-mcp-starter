JIRA_BASE_URL=https://jira.example.com
JIRA_PAT=replace_me

CONFLUENCE_BASE_URL=https://confluence.example.com
CONFLUENCE_PAT=replace_me

# Local run settings
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=8000

# Optional: set to false if your on-prem TLS uses a cert that your machine
# already trusts and you want normal verification.
ATLASSIAN_VERIFY_SSL=true
